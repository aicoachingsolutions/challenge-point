# Public client defaults for `vite build` / `vite preview` (local production-like).
# Adjust VITE_API_URL if the API listens on a different host or port.

VITE_PROJECT_NAME=challenge-point
VITE_PUBLIC_URL=/
VITE_API_URL=http://localhost:3001/api
VITE_API_LOGGING=false
VITE_INPUT_LABEL_CASE=title
VITE_LOCALE=GB
VITE_ONBOARDING=false
VITE_PROFILE_IMAGE_STRATEGY=hybrid

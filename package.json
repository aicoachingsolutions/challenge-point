{
    "name": "challenge-point",
    "version": "1.0.0",
    "author": "Verticode",
    "license": "ISC",
    "scripts": {
        "dev": "concurrently -p \"[ {name} ]\" -n \"BCK,FNT\" -c \"bgGreen.bold,bgBlue.bold\" \"npm run dev:back\" \"npm run dev:front\"",
        "dev:back": "npm --prefix ./back/ run dev",
        "dev:front": "npm --prefix ./front/ run dev",
        "start": "concurrently -p \"[ {name} ]\" -n \"BCK,FNT\" -c \"bgGreen.bold,bgBlue.bold\" \"npm run start:back\" \"npm run start:front\"",
        "start:back": "npm --prefix ./back/ run start",
        "start:front": "npm --prefix ./front/ run preview -- --host",
        "install:all": "npm install && concurrently -p \"[ {name} ]\" -n \"BCK,FNT\" -c \"bgGreen.bold,bgBlue.bold\" \"npm run install:back\" \"npm run install:front\"",
        "install:back": "npm --prefix ./back/ install",
        "install:front": "npm --prefix ./front/ install",
        "build": "concurrently -p \"[ {name} ]\" -n \"BCK,FNT\" -c \"bgGreen.bold,bgBlue.bold\" \"npm run build:back\" \"npm run build:front\"",
        "build:front": "npm --prefix ./front/ run build",
        "build:back": "npm --prefix ./back/ run build",
        "build:check": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\build-check.ps1",
        "mongo:up": "docker compose up -d",
        "mongo:down": "docker compose down"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.2.1",
        "concurrently": "^9.1.2",
        "eslint": "^8.57.0",
        "prettier": "^3.5.0"
    },
    "dependencies": {
        "openai": "^5.9.0"
    }
}

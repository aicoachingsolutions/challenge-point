# Copy to back/src/.env.production for real deployments, or rely on process env.
# Local production-like runs: this file is copied to dist/.env.production when src/.env.production is absent.

NODE_ENV=production
PROJECT_NAME=Challenge Point
SITE_URL=http://localhost:4173
HOST=0.0.0.0
PORT=3001

# Required: MongoDB connection string
DB_CONNECTION_STRING=mongodb://127.0.0.1:27017/challenge-point

# Required: use long random strings (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-local-jwt-secret
REFRESH_SECRET=change-me-local-refresh-secret

# Optional for local boot (set when using features that need them)
OPENAI_API_KEY=
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
EMAIL_FROM=

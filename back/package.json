{
    "name": "challenge-point-back",
    "version": "1.0.0",
    "author": "Verticode",
    "scripts": {
        "build": "node build.js",
        "dev": "nodemon",
        "start": "node dist/index.js"
    },
    "nodemonConfig": {
        "env": {
            "NODE_ENV": "development"
        },
        "watch": [
            "src"
        ],
        "ext": "ts, html",
        "ignore": [
            "src/public"
        ],
        "exec": "./node_modules/.bin/ts-node --files -r tsconfig-paths/register ./src"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.744.0",
        "@aws-sdk/s3-request-presigner": "^3.744.0",
        "bcrypt": "^5.0.1",
        "boilerplate": "file:..",
        "chalk": "^4.1.2",
        "challenge-point": "file:..",
        "command-line-args": "^5.2.1",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "dotenv": "^16.4.7",
        "express": "^4.18.1",
        "express-async-errors": "^3.1.1",
        "helmet": "^8.0.0",
        "http-status-codes": "^2.2.0",
        "jsonwebtoken": "^8.5.1",
        "mongoose": "^8.9.3",
        "morgan": "^1.10.0",
        "node-mailjet": "^5.1.1",
        "openai": "^6.34.0",
        "uuid": "^9.0.0",
        "winston": "^3.17.0",
        "winston-mongodb": "^6.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/command-line-args": "^5.2.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.13",
        "@types/fs-extra": "^9.0.13",
        "@types/jsonwebtoken": "^8.5.8",
        "@types/morgan": "^1.9.3",
        "@types/node": "^18.7.6",
        "@types/uuid": "^9.0.0",
        "@typescript-eslint/eslint-plugin": "^5.33.1",
        "@typescript-eslint/parser": "^5.33.1",
        "esbuild": "^0.23.1",
        "eslint": "^8.22.0",
        "fs-extra": "^10.1.0",
        "nodemon": "^2.0.19",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.1.0",
        "typescript": "^4.7.4"
    }
}
